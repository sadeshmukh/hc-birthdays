---
import Layout from "../layouts/Layout.astro";
import { getCurrentUser } from "../lib/session";
import {
  getUpcomingBirthdays,
  getAllBirthdays,
  getTodaysBirthdays,
  type User,
} from "../lib/db";

const currentUser = await getCurrentUser(Astro.cookies);

if (!currentUser) {
  return Astro.redirect("/api/auth/login");
}

const allBirthdays = await getAllBirthdays();
const upcomingBirthdays = await getUpcomingBirthdays(30);
const todaysBirthdays = await getTodaysBirthdays();

const channelIds = [...new Set(
  [...upcomingBirthdays, ...todaysBirthdays, ...allBirthdays]
    .map(u => u.slack_channel)
    .filter((c): c is string => !!c)
)];
const channelNames = new Map<string, string>();
await Promise.all(channelIds.map(async (id) => {
  try {
    const res = await fetch(`https://flaron.halceon.dev/channel/${id}`);
    if (res.ok) {
      const data = await res.json();
      if (data.name) channelNames.set(id, data.name);
    }
  } catch {}
}));

const today = new Date();
today.setHours(0, 0, 0, 0);

const mParam = parseInt(Astro.url.searchParams.get("m") || "");
const yParam = parseInt(Astro.url.searchParams.get("y") || "");
const viewMonth = mParam >= 1 && mParam <= 12 ? mParam : today.getMonth() + 1;
const viewYear = yParam > 2000 ? yParam : today.getFullYear();

const firstDayOfMonth = new Date(viewYear, viewMonth - 1, 1).getDay();
const daysInMonth = new Date(viewYear, viewMonth, 0).getDate();
const trailingCells =
  (firstDayOfMonth + daysInMonth) % 7 === 0
    ? 0
    : 7 - ((firstDayOfMonth + daysInMonth) % 7);

const birthdaysByDay = new Map<number, User[]>();
for (const user of allBirthdays) {
  if (user.birthday_month === viewMonth) {
    const d = user.birthday_day!;
    if (!birthdaysByDay.has(d)) birthdaysByDay.set(d, []);
    birthdaysByDay.get(d)!.push(user);
  }
}

const prevDate = new Date(viewYear, viewMonth - 2, 1);
const nextDate = new Date(viewYear, viewMonth, 1);
const prevLink = `/?m=${prevDate.getMonth() + 1}&y=${prevDate.getFullYear()}`;
const nextLink = `/?m=${nextDate.getMonth() + 1}&y=${nextDate.getFullYear()}`;

const MONTH_NAMES = [
  "January","February","March","April","May","June",
  "July","August","September","October","November","December",
];
const SHORT_MONTHS = [
  "Jan","Feb","Mar","Apr","May","Jun",
  "Jul","Aug","Sep","Oct","Nov","Dec",
];
const DAY_HEADERS = ["Su", "Mo", "Tu", "We", "Th", "Fr", "Sa"];

function getDaysUntil(user: User): number {
  const t = new Date();
  t.setHours(0, 0, 0, 0);
  let bd = new Date(t.getFullYear(), user.birthday_month! - 1, user.birthday_day!);
  bd.setHours(0, 0, 0, 0);
  if (bd < t)
    bd = new Date(t.getFullYear() + 1, user.birthday_month! - 1, user.birthday_day!);
  return Math.round((bd.getTime() - t.getTime()) / 86400000);
}

const error = Astro.url.searchParams.get("error");
---

<Layout title="HC Birthdays">
  <nav slot="header-right" class="flex items-center gap-4">
    <a
      href="/profile"
      class="flex items-center gap-2 hover:opacity-70 transition-opacity"
    >
      {currentUser.avatar_url && (
        <img src={currentUser.avatar_url} alt="" class="w-7 h-7 rounded-full" />
      )}
      <span class="text-sm text-[#aaa]">@{currentUser.slack_username}</span>
    </a>
    <a
      href="/api/auth/logout"
      class="text-sm text-[#666] hover:text-[#aaa] transition-colors"
    >
      logout
    </a>
  </nav>

  {error && (
    <div class="mb-6 text-sm text-[#ec3750] border border-[#ec3750]/30 bg-[#ec3750]/5 rounded-md px-4 py-3">
      auth error: {error}
    </div>
  )}

  <!-- Calendar -->
  <div class="mb-10">
    <div class="flex items-center justify-between mb-4">
      <a href={prevLink} class="text-[#666] hover:text-[#aaa] transition-colors px-1 py-1 text-lg leading-none">‹</a>
      <span class="text-sm font-medium text-[#999]">{MONTH_NAMES[viewMonth - 1]} {viewYear}</span>
      <a href={nextLink} class="text-[#666] hover:text-[#aaa] transition-colors px-1 py-1 text-lg leading-none">›</a>
    </div>

    <div class="grid grid-cols-7 mb-px">
      {DAY_HEADERS.map((d) => (
        <div class="text-center text-[10px] text-[#555] font-medium uppercase tracking-wider py-2">{d}</div>
      ))}
    </div>

    <div class="grid grid-cols-7 gap-px bg-[#1a1a1a]">
      {Array.from({ length: firstDayOfMonth }, () => (
        <div class="bg-[#0d0d0d] min-h-18 p-1.5" />
      ))}
      {Array.from({ length: daysInMonth }, (_, i) => {
        const day = i + 1;
        const isToday =
          day === today.getDate() &&
          viewMonth === today.getMonth() + 1 &&
          viewYear === today.getFullYear();
        const users = birthdaysByDay.get(day) || [];
        const cellData = users.length > 0
          ? JSON.stringify(users.map(u => ({
              username: u.slack_username,
              avatar: u.avatar_url,
              year: u.birth_year,
              channelId: u.slack_channel ?? null,
              channelName: u.slack_channel ? (channelNames.get(u.slack_channel) ?? null) : null,
            })))
          : null;
        return (
          <div
            class={`bg-[#0d0d0d] min-h-18 p-1.5 flex flex-col ${isToday ? "bg-[#111]" : ""} ${users.length > 0 ? "cursor-pointer hover:bg-[#131313] transition-colors" : ""}`}
            data-users={cellData ?? undefined}
          >
            <span
              class={`text-[11px] w-5 h-5 flex items-center justify-center rounded-full mb-1 shrink-0 ${isToday ? "bg-[#ec3750] text-white font-semibold" : "text-[#555]"}`}
            >
              {day}
            </span>
            <div class="flex flex-wrap gap-0.5">
              {users.slice(0, 5).map((u) =>
                u.avatar_url ? (
                  <img
                    src={u.avatar_url}
                    alt={u.slack_username}
                    class="w-5 h-5 rounded-full"
                  />
                ) : (
                  <div
                    class="w-5 h-5 rounded-full bg-[#222] flex items-center justify-center text-[9px] text-[#777]"
                  >
                    {u.slack_username[0].toUpperCase()}
                  </div>
                )
              )}
              {users.length > 5 && (
                <span class="text-[#666] text-[9px] self-center">+{users.length - 5}</span>
              )}
            </div>
          </div>
        );
      })}
      {Array.from({ length: trailingCells }, () => (
        <div class="bg-[#0d0d0d] min-h-18 p-1.5" />
      ))}
    </div>
  </div>

  <!-- Calendar popup -->
  <div
    id="cal-popup"
    class="hidden fixed z-50 bg-[#161616] border border-[#2a2a2a] rounded-lg p-3 shadow-xl min-w-48 max-w-72"
  ></div>

  {todaysBirthdays.length > 0 && (
    <div class="mb-8 border border-[#ec3750]/20 rounded-lg p-4">
      <p class="text-xs text-[#ec3750] uppercase tracking-wider mb-3">Today</p>
      <div class="flex flex-col gap-3">
        {todaysBirthdays.map((user) => (
          <div class="flex items-center gap-3">
            {user.avatar_url ? (
              <img src={user.avatar_url} alt="" class="w-8 h-8 rounded-full" />
            ) : (
              <div class="w-8 h-8 rounded-full bg-[#1a1a1a] flex items-center justify-center text-sm text-[#666]">
                {user.slack_username[0].toUpperCase()}
              </div>
            )}
            <span class="text-sm text-[#e2e2e2]">@{user.slack_username}</span>
            {user.slack_channel && channelNames.get(user.slack_channel) && (
              <a
                href={`https://hackclub.slack.com/archives/${user.slack_channel}`}
                target="_blank"
                rel="noopener noreferrer"
                class="text-sm text-[#666] hover:text-[#aaa] transition-colors"
              >
                #{channelNames.get(user.slack_channel)}
              </a>
            )}
            {user.birth_year && (
              <span class="text-[#666] text-sm">· turning {today.getFullYear() - user.birth_year}</span>
            )}
          </div>
        ))}
      </div>
    </div>
  )}

  <!-- Upcoming list -->
  <div>
    <p class="text-xs text-[#555] uppercase tracking-wider mb-3">Upcoming</p>

    {upcomingBirthdays.length === 0 ? (
      <p class="text-[#666] text-sm">
        No birthdays in the next 30 days.{" "}
        <a href="/profile" class="text-[#ec3750] hover:opacity-80 transition-opacity">Add yours.</a>
      </p>
    ) : (
      <div class="flex flex-col divide-y divide-[#151515]">
        {upcomingBirthdays.map((user) => {
          const daysUntil = getDaysUntil(user);
          return (
            <div class="flex items-center gap-3 py-2.5">
              {user.avatar_url ? (
                <img src={user.avatar_url} alt="" class="w-7 h-7 rounded-full shrink-0" />
              ) : (
                <div class="w-7 h-7 rounded-full bg-[#1a1a1a] flex items-center justify-center text-xs text-[#666] shrink-0">
                  {user.slack_username[0].toUpperCase()}
                </div>
              )}
              <span class="text-sm flex-1 min-w-0 truncate text-[#ccc]">
                @{user.slack_username}
              </span>
              {user.slack_channel && channelNames.get(user.slack_channel) && (
                <a
                  href={`https://hackclub.slack.com/archives/${user.slack_channel}`}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="text-sm text-[#666] hover:text-[#aaa] transition-colors shrink-0 hidden sm:block"
                >
                  #{channelNames.get(user.slack_channel)}
                </a>
              )}
              <span class="text-sm text-[#666] shrink-0">
                {SHORT_MONTHS[user.birthday_month! - 1]} {user.birthday_day}
              </span>
              <span class="text-sm shrink-0 w-16 text-right">
                {daysUntil === 0 ? (
                  <span class="text-[#ec3750]">today</span>
                ) : daysUntil === 1 ? (
                  <span class="text-[#999]">tomorrow</span>
                ) : (
                  <span class="text-[#555]">in {daysUntil}d</span>
                )}
              </span>
            </div>
          );
        })}
      </div>
    )}
  </div>
</Layout>

<script>
  const popup = document.getElementById('cal-popup')!;

  document.querySelectorAll<HTMLElement>('[data-users]').forEach((cell) => {
    cell.addEventListener('click', (e) => {
      e.stopPropagation();
      const users: {
        username: string;
        avatar: string | null;
        year: number | null;
        channelId: string | null;
        channelName: string | null;
      }[] = JSON.parse(cell.dataset.users!);

      const thisYear = new Date().getFullYear();

      popup.innerHTML = users.map((u) => `
        <div class="flex items-center gap-2 py-1">
          ${u.avatar
            ? `<img src="${u.avatar}" class="w-6 h-6 rounded-full shrink-0">`
            : `<div class="w-6 h-6 rounded-full bg-[#222] flex items-center justify-center text-[10px] text-[#888] shrink-0">${u.username[0].toUpperCase()}</div>`
          }
          <span class="text-sm text-[#e2e2e2]">@${u.username}</span>
          ${u.channelId && u.channelName
            ? `<a href="https://hackclub.slack.com/archives/${u.channelId}" target="_blank" class="text-sm text-[#666] hover:text-[#aaa] transition-colors">#${u.channelName}</a>`
            : ''
          }
          ${u.year ? `<span class="text-[#555] text-xs shrink-0">· turning ${thisYear - u.year}</span>` : ''}
        </div>
      `).join('');

      const rect = cell.getBoundingClientRect();
      const popupWidth = 260;
      let left = rect.left + window.scrollX;
      let top = rect.bottom + window.scrollY + 6;

      if (left + popupWidth > window.innerWidth - 8) {
        left = window.innerWidth - popupWidth - 8;
      }

      popup.style.left = `${left}px`;
      popup.style.top = `${top}px`;
      popup.classList.remove('hidden');
    });
  });

  document.addEventListener('click', () => {
    popup.classList.add('hidden');
  });
</script>
