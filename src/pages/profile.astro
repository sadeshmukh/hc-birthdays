---
import Layout from "../layouts/Layout.astro";
import { getCurrentUser } from "../lib/session";

const currentUser = await getCurrentUser(Astro.cookies);

if (!currentUser) {
	return Astro.redirect("/api/auth/login");
}

let channelName: string | null = currentUser.slack_channel_name;
let channelIsPrivate: boolean = currentUser.slack_channel_is_private ?? false;

if (currentUser.slack_channel && !channelName) {
	try {
		const res = await fetch(
			`https://flaron.halceon.dev/channel/${currentUser.slack_channel}`,
		);
		if (res.ok) {
			const data = await res.json();
			channelName = data.name ?? null;
			channelIsPrivate = !("created" in data);
		}
	} catch {}
}

const MONTHS = [
	"January",
	"February",
	"March",
	"April",
	"May",
	"June",
	"July",
	"August",
	"September",
	"October",
	"November",
	"December",
];
const currentYear = new Date().getFullYear();
---

<Layout title="Your Birthday — HC Birthdays">
  <nav slot="header-right" class="flex items-center gap-4">
    <a href="/" class="text-sm text-[#555] hover:text-[#aaa] transition-colors"
      >← back</a
    >
    <a
      href="/api/auth/logout"
      class="text-sm text-[#555] hover:text-[#aaa] transition-colors">logout</a
    >
  </nav>

  <div class="max-w-sm">
    <div class="flex items-center gap-3 mb-8">
      {
        currentUser.avatar_url ? (
          <img
            src={currentUser.avatar_url}
            alt=""
            class="w-9 h-9 rounded-full"
          />
        ) : (
          <div class="w-9 h-9 rounded-full bg-[#1a1a1a] flex items-center justify-center text-sm text-[#555]">
            {currentUser.slack_username[0].toUpperCase()}
          </div>
        )
      }
      <div>
        <p class="text-sm font-medium">@{currentUser.slack_username}</p>
        <p class="text-xs text-[#555]">birthday settings</p>
      </div>
    </div>

    <form action="/api/birthday" method="POST" class="flex flex-col gap-5">
      <div class="grid grid-cols-2 gap-3">
        <div class="flex flex-col gap-1.5">
          <label
            for="month"
            class="text-[10px] text-[#555] uppercase tracking-wider"
            >Month</label
          >
          <select
            id="month"
            name="month"
            required
            class="bg-[#161616] border border-[#252525] rounded-md px-3 py-2 text-sm text-[#e2e2e2] focus:outline-none focus:border-[#ec3750] focus:ring-0"
          >
            <option value="">—</option>
            {
              MONTHS.map((m, i) => (
                <option
                  value={i + 1}
                  selected={currentUser.birthday_month === i + 1}
                >
                  {m}
                </option>
              ))
            }
          </select>
        </div>
        <div class="flex flex-col gap-1.5">
          <label
            for="day"
            class="text-[10px] text-[#555] uppercase tracking-wider">Day</label
          >
          <select
            id="day"
            name="day"
            required
            class="bg-[#161616] border border-[#252525] rounded-md px-3 py-2 text-sm text-[#e2e2e2] focus:outline-none focus:border-[#ec3750] focus:ring-0"
          >
            <option value="">—</option>
            {
              Array.from({ length: 31 }, (_, i) => i + 1).map((d) => (
                <option value={d} selected={currentUser.birthday_day === d}>
                  {d}
                </option>
              ))
            }
          </select>
        </div>
      </div>

      <div class="flex flex-col gap-1.5">
        <label
          for="year"
          class="text-[10px] text-[#555] uppercase tracking-wider"
        >
          Year <span class="text-[#333] normal-case not-italic">optional</span>
        </label>
        <select
          id="year"
          name="year"
          class="bg-[#161616] border border-[#252525] rounded-md px-3 py-2 text-sm text-[#e2e2e2] focus:outline-none focus:border-[#ec3750] focus:ring-0"
        >
          <option value="">prefer not to say</option>
          {
            Array.from({ length: 50 }, (_, i) => currentYear - i).map((y) => (
              <option value={y} selected={currentUser.birth_year === y}>
                {y}
              </option>
            ))
          }
        </select>
      </div>

      <div class="flex flex-col gap-1.5">
        <label
          for="channel-search"
          class="text-[10px] text-[#555] uppercase tracking-wider"
        >
          Slack channel <span class="text-[#333] normal-case">optional</span>
        </label>

        <input
          type="hidden"
          name="channel"
          id="channel-value"
          value={currentUser.slack_channel || ""}
        />
        <input
          type="hidden"
          name="channel_name"
          id="channel-name-value"
          value={channelName || ""}
        />
        <input
          type="hidden"
          name="channel_is_private"
          id="channel-private-value"
          value={String(channelIsPrivate)}
        />

        <!-- Selected channel display -->
        <div
          id="channel-display"
          class={`${channelName ? "flex" : "hidden"} items-center gap-2 bg-[#161616] border border-[#252525] rounded-md px-3 py-2`}
        >
          <span
            class="text-sm text-[#e2e2e2] truncate"
            id="channel-display-name"
          >
            {channelName ? `#${channelName}` : ""}
          </span>
          <span
            class="text-xs text-[#444] font-mono ml-auto shrink-0"
            id="channel-display-id"
          >
            {currentUser.slack_channel || ""}
          </span>
          <span
            id="channel-display-private"
            class={`text-[10px] text-[#777] border border-[#2a2a2a] rounded px-1 py-0.5 shrink-0 ${channelIsPrivate ? "" : "hidden"}`}
            >private</span
          >
          <button
            type="button"
            id="channel-clear"
            class="text-[#444] hover:text-[#888] text-base leading-none ml-1 shrink-0"
            aria-label="Clear channel">×</button
          >
        </div>

        <!-- Search input -->
        <div
          id="channel-search-wrapper"
          class={`${channelName ? "hidden" : ""} relative`}
        >
          <input
            type="text"
            id="channel-search"
            autocomplete="off"
            placeholder="search by name or paste channel ID"
            value={!channelName && currentUser.slack_channel
              ? currentUser.slack_channel
              : ""}
            class="w-full bg-[#161616] border border-[#252525] rounded-md px-3 py-2 text-sm text-[#e2e2e2] placeholder:text-[#333] focus:outline-none focus:border-[#ec3750]"
          />
          <div
            id="channel-dropdown"
            class="hidden absolute z-10 top-full mt-1 left-0 right-0 bg-[#161616] border border-[#252525] rounded-md shadow-xl overflow-hidden"
          >
            <div id="channel-dropdown-content"></div>
          </div>
        </div>

        <p
          id="channel-status"
          class={`text-[11px] text-[#ec3750] ${!currentUser.slack_channel || channelName ? "hidden" : ""}`}
        >
          channel not found · try searching by name if possible
        </p>

        <p
          id="channel-private-note"
          class={`text-[11px] text-[#555] ${channelIsPrivate ? "" : "hidden"}`}
        >
          private channel — its name won't be shown to others
        </p>

        <p class="text-[11px] text-[#333]">
          so people can wish you happy birthday
        </p>
      </div>

      <button
        type="submit"
        class="bg-[#ec3750] hover:bg-[#d42f46] text-white text-sm font-medium py-2 px-4 rounded-md transition-colors"
      >
        Save
      </button>
    </form>
  </div>
</Layout>

<script>
  const form = document.querySelector<HTMLFormElement>("form")!;
  const hiddenId = document.getElementById("channel-value") as HTMLInputElement;
  const hiddenName = document.getElementById(
    "channel-name-value",
  ) as HTMLInputElement;
  const hiddenPrivate = document.getElementById(
    "channel-private-value",
  ) as HTMLInputElement;
  const display = document.getElementById("channel-display")!;
  const displayName = document.getElementById("channel-display-name")!;
  const displayId = document.getElementById("channel-display-id")!;
  const displayPrivate = document.getElementById("channel-display-private")!;
  const clearBtn = document.getElementById("channel-clear")!;
  const searchWrapper = document.getElementById("channel-search-wrapper")!;
  const searchInput = document.getElementById(
    "channel-search",
  ) as HTMLInputElement;
  const dropdown = document.getElementById("channel-dropdown")!;
  const dropdownContent = document.getElementById("channel-dropdown-content")!;
  const statusEl = document.getElementById("channel-status")!;
  const privateNote = document.getElementById("channel-private-note")!;

  let debounceTimer: ReturnType<typeof setTimeout>;

  function renderDropdownItem(
    name: string,
    id: string,
    isPrivate: boolean,
  ): HTMLButtonElement {
    const btn = document.createElement("button");
    btn.type = "button";
    btn.className =
      "w-full flex items-center gap-2 px-3 py-2.5 hover:bg-[#1a1a1a] text-left transition-colors";
    btn.innerHTML = `
      <span class="text-sm text-[#e2e2e2]">#${name}</span>
      <span class="text-xs text-[#444] font-mono ml-auto shrink-0">${id}</span>
      ${isPrivate ? '<span class="text-[10px] text-[#777] border border-[#2a2a2a] rounded px-1 py-0.5 shrink-0">private</span>' : ""}
    `;
    btn.addEventListener("click", () => showSelected(name, id, isPrivate));
    return btn;
  }

  function showSelected(name: string, id: string, isPrivate: boolean) {
    hiddenId.value = id;
    hiddenName.value = name;
    hiddenPrivate.value = String(isPrivate);
    displayName.textContent = `#${name}`;
    displayId.textContent = id;
    displayPrivate.classList.toggle("hidden", !isPrivate);
    display.classList.remove("hidden");
    display.classList.add("flex");
    searchWrapper.classList.add("hidden");
    dropdown.classList.add("hidden");
    statusEl.classList.add("hidden");
    privateNote.classList.toggle("hidden", !isPrivate);
  }

  function showSearch() {
    display.classList.add("hidden");
    display.classList.remove("flex");
    searchWrapper.classList.remove("hidden");
    searchInput.value = "";
    hiddenId.value = "";
    hiddenName.value = "";
    hiddenPrivate.value = "false";
    statusEl.classList.add("hidden");
    privateNote.classList.add("hidden");
    searchInput.focus();
  }

  clearBtn.addEventListener("click", showSearch);

  const ID_RE = /^[CG][A-Z0-9]{5,}/i;

  searchInput.addEventListener("input", () => {
    clearTimeout(debounceTimer);
    const q = searchInput.value.trim();

    if (!q) {
      dropdown.classList.add("hidden");
      statusEl.classList.add("hidden");
      return;
    }

    debounceTimer = setTimeout(async () => {
      try {
        if (ID_RE.test(q)) {
          const res = await fetch(`/api/channel?id=${encodeURIComponent(q)}`);
          const data = (await res.json()) as {
            found: boolean;
            name?: string;
            id?: string;
            is_private?: boolean;
          };
          if (data.found && data.name && data.id) {
            dropdownContent.replaceChildren(
              renderDropdownItem(data.name, data.id, data.is_private ?? false),
            );
            dropdown.classList.remove("hidden");
            statusEl.classList.add("hidden");
          } else {
            dropdown.classList.add("hidden");
            statusEl.textContent =
              "channel not found · try searching by name if possible";
            statusEl.classList.remove("hidden");
          }
        } else {
          type ExactResult = {
            found: boolean;
            name?: string;
            id?: string;
            is_private?: boolean;
          };
          type SearchResult = {
            results: { name: string; id: string; is_private: boolean }[];
          };
          const [exactRes, searchRes] = await Promise.all([
            fetch(`/api/channel?id=${encodeURIComponent(q)}`),
            fetch(`/api/channel?q=${encodeURIComponent(q)}`),
          ]);
          const exact = (await exactRes.json()) as ExactResult;
          const search = (await searchRes.json()) as SearchResult;

          const items: HTMLButtonElement[] = [];

          if (exact.found && exact.name && exact.id) {
            items.push(
              renderDropdownItem(
                exact.name,
                exact.id,
                exact.is_private ?? false,
              ),
            );
          }

          for (const r of search.results ?? []) {
            if (r.id !== exact.id) {
              items.push(renderDropdownItem(r.name, r.id, r.is_private));
            }
          }

          if (items.length > 0) {
            dropdownContent.replaceChildren(...items);
            dropdown.classList.remove("hidden");
            statusEl.classList.add("hidden");
          } else {
            dropdown.classList.add("hidden");
            statusEl.classList.add("hidden");
          }
        }
      } catch {
        dropdown.classList.add("hidden");
      }
    }, 300);
  });

  document.addEventListener("click", (e) => {
    if (!searchWrapper.contains(e.target as Node)) {
      dropdown.classList.add("hidden");
    }
  });
</script>
