---
import '../styles/global.css';

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Hack Club Birthdays - Celebrate with your fellow hackers!" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
  </head>
  <body class="min-h-screen bg-gradient-to-br from-purple-900 via-indigo-900 to-blue-900 text-white">
    <div class="min-h-screen flex flex-col">
      <header class="border-b border-white/10 backdrop-blur-sm bg-white/5">
        <div class="max-w-4xl mx-auto px-4 py-4 flex items-center justify-between">
          <a href="/" class="flex items-center gap-3 hover:opacity-80 transition">
            <span class="text-3xl">🎂</span>
            <span class="text-xl font-bold">HC Birthdays</span>
          </a>
          <slot name="header-right" />
        </div>
      </header>
      <main class="flex-1 max-w-4xl mx-auto px-4 py-8 w-full">
        <slot />
      </main>
      <footer class="border-t border-white/10 py-6">
        <div class="max-w-4xl mx-auto px-4 text-center text-white/60 text-sm">
          Made with love for <a href="https://hackclub.com" class="text-white/80 hover:text-white underline">Hack Club</a>
        </div>
      </footer>
    </div>
  </body>
</html>
