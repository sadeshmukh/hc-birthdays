---
import "../styles/global.css";

interface Props {
	title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Hack Club Birthdays" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
  </head>
  <body class="min-h-screen bg-[#0d0d0d] text-[#e2e2e2] antialiased">
    <header class="border-b border-[#1f1f1f]">
      <div
        class="max-w-5xl mx-auto px-6 h-14 flex items-center justify-between"
      >
        <a
          href="/"
          class="text-sm font-medium text-[#e2e2e2] hover:text-white transition-colors"
        >
          hc birthdays
        </a>
        <slot name="header-right" />
      </div>
    </header>
    <main class="max-w-5xl mx-auto px-6 py-8 w-full">
      <slot />
    </main>
    <footer class="border-t border-[#1f1f1f] py-6 mt-12">
      <div class="max-w-5xl mx-auto px-6 text-center text-[#333] text-xs">
        <a
          href="https://hackclub.com"
          class="hover:text-[#666] transition-colors">hack club</a
        >
      </div>
    </footer>
  </body>
</html>
